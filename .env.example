APP_NAME=Face Recognition System
APP_VERSION=1.0.0
LOG_LEVEL=INFO
CASCADE_FILE_PATH=data/haarcascade_frontalface_default.xml
DATABASE_PATH=data/face_recognition.db
ENCODINGS_DIR=data/encodings
LOGS_DIR=data/logs
CAMERA_SOURCE=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
RECOGNITION_TOLERANCE=0.5
CAPTURE_COUNT=5
MIN_CONFIDENCE=0.5
EXPORT_FORMAT=csv
DATE_FORMAT=%Y-%m-%d %H:%M:%S
